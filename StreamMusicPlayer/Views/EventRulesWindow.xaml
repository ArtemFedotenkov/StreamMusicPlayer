<Window x:Class="StreamMusicPlayer.Views.EventRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:StreamMusicPlayer.Views"
        Title="{DynamicResource EventRulesWindowTitle}"
        Width="1120"
        Height="640"
        MinWidth="980"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Icon="/iconka.ico"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <views:AutomationEventDisplayNameConverter x:Key="AutomationEventDisplayNameConverter" />
        <views:AutomationEventConditionConverter x:Key="AutomationEventConditionConverter" />
        <views:AutomationActionDisplayNameConverter x:Key="AutomationActionDisplayNameConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Padding="10"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="{DynamicResource AutomationRulesHeader}"
                           Margin="2,0,0,8"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="+" Command="{Binding AddRuleCommand}" ToolTip="{DynamicResource ButtonAdd}" />
                    <Button Content="-" Command="{Binding RemoveRuleCommand}" ToolTip="{DynamicResource ButtonRemove}" Margin="0" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Rules}"
                         SelectedItem="{Binding SelectedRule}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="True"
                                     Focusable="False"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0"
                                     PreviewMouseDoubleClick="RuleNameTextBox_PreviewMouseDoubleClick"
                                     LostFocus="RuleNameTextBox_LostFocus"
                                     KeyDown="RuleNameTextBox_KeyDown" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Padding="10"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="{DynamicResource AutomationEventsHeader}"
                           Margin="2,0,0,8"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="+" Click="OpenEventContextMenuButton_Click" ToolTip="{DynamicResource ButtonAdd}" />
                    <Button Content="-" Command="{Binding RemoveEventCommand}" ToolTip="{DynamicResource ButtonRemove}" Margin="0" />
                </StackPanel>
                <ListBox ItemsSource="{Binding CurrentEvents}"
                         SelectedItem="{Binding SelectedEvent}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding EventType, Converter={StaticResource AutomationEventDisplayNameConverter}}" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SourceType}" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
                                    <TextBlock Text=" / " FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
                                    <TextBlock Text="{Binding SettingsJson, Converter={StaticResource AutomationEventConditionConverter}}" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="4"
                Padding="10"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="{DynamicResource AutomationActionsHeader}"
                           Margin="2,0,0,8"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="+" Click="OpenActionContextMenuButton_Click" ToolTip="{DynamicResource AddActionButton}" />
                    <Button Content="-" Command="{Binding RemoveActionCommand}" ToolTip="{DynamicResource ButtonRemove}" Margin="0" />
                </StackPanel>
                <ListBox x:Name="ActionsListBox"
                         ItemsSource="{Binding CurrentActions}"
                         SelectedItem="{Binding SelectedAction}"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="ActionsListBox_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="ActionsListBox_PreviewMouseMove"
                         Drop="ActionsListBox_Drop">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding ActionType, Converter={StaticResource AutomationActionDisplayNameConverter}}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TargetType}" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="6"
                Padding="14"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasSelectedAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource AutomationInspectorHeader}"
                               Margin="2,0,0,12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedTextBrush}" />

                    <TextBlock Text="{Binding SelectedActionDisplayName}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14" />

                    <StackPanel Visibility="{Binding CanEditActionScene, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{DynamicResource SceneCondition}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding Scenes}" SelectedItem="{Binding SelectedActionSceneName}" Margin="0,0,0,12" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding CanEditActionPlaylist, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{DynamicResource Playlist}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding Playlists}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding SelectedActionPlaylistId}" Margin="0,0,0,12" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding CanEditActionTrack, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{DynamicResource Track}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding ActionTracks}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding SelectedActionTrackId}" Margin="0,0,0,12" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding CanEditActionFilter, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <CheckBox Content="{DynamicResource Enabled}" IsChecked="{Binding SelectedActionFilterEnabled}" Margin="0,0,0,12" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding CanEditActionVolume, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{DynamicResource Volume}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,5" />
                        <TextBox Text="{Binding SelectedActionVolume, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding CanEditActionCrossfade, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{DynamicResource CrossfadeSeconds}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,5" />
                        <TextBox Text="{Binding SelectedActionCrossfadeSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="7"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock Text="{Binding StatusMessage}"
                       Width="520"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <Button Content="{DynamicResource ButtonSave}" Command="{Binding SaveRulesCommand}" />
            <Button Content="{DynamicResource ButtonClose}" Margin="0" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
