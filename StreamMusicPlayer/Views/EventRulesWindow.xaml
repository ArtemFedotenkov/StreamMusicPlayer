<Window x:Class="StreamMusicPlayer.Views.EventRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource EventRulesWindowTitle}"
        Width="860"
        Height="560"
        WindowStartupLocation="CenterOwner"
        Icon="/iconka.ico"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Padding="12"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="{DynamicResource ButtonAdd}" Command="{Binding AddRuleCommand}" />
                    <Button Content="{DynamicResource ButtonRemove}" MinWidth="92" Command="{Binding RemoveRuleCommand}" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Rules}"
                         SelectedItem="{Binding SelectedRule}"
                         DisplayMemberPath="Name" />
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Padding="16"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="152" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource Name}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBox Grid.Column="1" Text="{Binding SelectedRuleName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1" Text="{DynamicResource Enabled}" Foreground="{DynamicResource MutedTextBrush}" />
                <CheckBox Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding SelectedRuleEnabled}" />

                <TextBlock Grid.Row="2" Text="{DynamicResource EventType}" Foreground="{DynamicResource MutedTextBrush}" />
                <ComboBox Grid.Row="2" Grid.Column="1"
                          ItemsSource="{Binding TriggerTypes}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedTriggerType}" />

                <TextBlock Grid.Row="3"
                           Text="{DynamicResource SceneCondition}"
                           IsEnabled="{Binding CanSelectTriggerCondition}"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <ComboBox Grid.Row="3" Grid.Column="1"
                          IsEnabled="{Binding CanSelectTriggerCondition}"
                          ItemsSource="{Binding SceneNames}"
                          SelectedItem="{Binding SelectedTriggerCondition, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="4" Text="{DynamicResource Action}" Foreground="{DynamicResource MutedTextBrush}" />
                <ComboBox Grid.Row="4" Grid.Column="1"
                          ItemsSource="{Binding ActionTypes}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedActionType}" />

                <TextBlock Grid.Row="5"
                           Text="{DynamicResource Playlist}"
                           IsEnabled="{Binding CanSelectActionPlaylist}"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <ComboBox Grid.Row="5" Grid.Column="1"
                          IsEnabled="{Binding CanSelectActionPlaylist}"
                          ItemsSource="{Binding PlaylistNames}"
                          SelectedItem="{Binding SelectedActionPlaylistName}" />

                <TextBlock Grid.Row="6"
                           Text="{DynamicResource CrossfadeSeconds}"
                           IsEnabled="{Binding CanEditActionCrossfade}"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <TextBox Grid.Row="6" Grid.Column="1"
                         IsEnabled="{Binding CanEditActionCrossfade}"
                         Text="{Binding SelectedActionCrossfadeSeconds, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="7"
                           Text="{DynamicResource Volume}"
                           IsEnabled="{Binding CanEditActionVolume}"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <TextBox Grid.Row="7" Grid.Column="1"
                         IsEnabled="{Binding CanEditActionVolume}"
                         Text="{Binding SelectedActionVolume, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="8" Text="{DynamicResource PriorityDelay}" Foreground="{DynamicResource MutedTextBrush}" />
                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <TextBox Width="120" Text="{Binding SelectedPriority, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Width="120"
                             Margin="8,0,0,0"
                             Text="{Binding SelectedDelaySeconds, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <TextBlock Grid.Row="9"
                           Grid.ColumnSpan="2"
                           VerticalAlignment="Top"
                           Text="{Binding SelectedRule.ActionJson}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock Text="{Binding StatusMessage}"
                       Width="420"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <Button Content="{DynamicResource ButtonSave}" Command="{Binding SaveRulesCommand}" />
            <Button Content="{DynamicResource ButtonClose}" Margin="0" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
