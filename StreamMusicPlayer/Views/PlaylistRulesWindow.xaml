<Window x:Class="StreamMusicPlayer.Views.PlaylistRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource PlaylistRulesWindowTitle}"
        Width="560"
        Height="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="/iconka.ico"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource Playlist}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Playlist.Name}"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="1" Text="{DynamicResource PlaybackBehavior}" Foreground="{DynamicResource MutedTextBrush}" />
                <ComboBox Grid.Row="1"
                          Grid.Column="1"
                          ItemsSource="{Binding PlayModes}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding PlayMode}" />

                <TextBlock Grid.Row="2" Text="{DynamicResource ShuffleRepeatAll}" Foreground="{DynamicResource MutedTextBrush}" />
                <CheckBox Grid.Row="2"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          IsEnabled="{Binding CanShuffle}"
                          IsChecked="{Binding ShuffleEnabled}" />

                <TextBlock Grid.Row="3" Text="{DynamicResource AfterPlaylistEnds}" Foreground="{DynamicResource MutedTextBrush}" />
                <ComboBox Grid.Row="3"
                          Grid.Column="1"
                          ItemsSource="{Binding CompletionActions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding CompletionAction}" />

                <TextBlock Grid.Row="4" Text="{DynamicResource SpecificPlaylist}" Foreground="{DynamicResource MutedTextBrush}" />
                <ComboBox Grid.Row="4"
                          Grid.Column="1"
                          ItemsSource="{Binding Playlists}"
                          DisplayMemberPath="Name"
                          IsEnabled="{Binding NeedsSpecificPlaylist}"
                          SelectedItem="{Binding CompletionPlaylist}" />

                <TextBlock Grid.Row="5" Text="{DynamicResource DefaultCrossfade}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Text="{Binding DefaultCrossfadeSeconds, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="6" Text="{DynamicResource DefaultVolume}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBox Grid.Row="6"
                         Grid.Column="1"
                         VerticalAlignment="Top"
                         Text="{Binding DefaultVolume, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock Text="{Binding StatusMessage}"
                       Width="260"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <Button Content="{DynamicResource ButtonSave}" Command="{Binding SaveCommand}" />
            <Button Content="{DynamicResource ButtonClose}" Margin="0" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
