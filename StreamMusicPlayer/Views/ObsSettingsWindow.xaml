<Window x:Class="StreamMusicPlayer.Views.ObsSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ObsSettingsWindowTitle}"
        Width="560"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="/iconka.ico"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="168" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="56" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="44" />
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource Host}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBox Grid.Column="1" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1" Text="{DynamicResource Port}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2" Text="{DynamicResource Password}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3" Text="{DynamicResource AutoConnect}" Foreground="{DynamicResource MutedTextBrush}" />
                <CheckBox Grid.Row="3" Grid.Column="1"
                          VerticalAlignment="Center"
                          IsChecked="{Binding AutoConnectOnStartup}" />

                <TextBlock Grid.Row="4" Text="{DynamicResource AutoReconnect}" Foreground="{DynamicResource MutedTextBrush}" />
                <CheckBox Grid.Row="4" Grid.Column="1"
                          VerticalAlignment="Center"
                          IsChecked="{Binding ReconnectAutomatically}" />

                <TextBlock Grid.Row="5" Text="{DynamicResource ReconnectInterval}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ReconnectIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />

                <WrapPanel Grid.Row="6" Grid.ColumnSpan="2" VerticalAlignment="Center">
                    <Button Content="{DynamicResource ButtonConnect}" Command="{Binding ConnectCommand}" />
                    <Button Content="{DynamicResource ButtonDisconnect}" MinWidth="96" Command="{Binding DisconnectCommand}" />
                    <Button Content="{DynamicResource ButtonRefreshScenes}" MinWidth="122" Command="{Binding RefreshScenesCommand}" />
                </WrapPanel>

                <TextBlock Grid.Row="7" Text="{DynamicResource ObsVersion}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding ObsVersion}" />

                <TextBlock Grid.Row="8" Text="{DynamicResource WebSocketVersion}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding WebSocketVersion}" />

                <TextBlock Grid.Row="9" Text="{DynamicResource CurrentScene}" Foreground="{DynamicResource MutedTextBrush}" />
                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding CurrentScene}" />

                <ListBox Grid.Row="10"
                         Grid.ColumnSpan="2"
                         ItemsSource="{Binding Scenes}" />

                <TextBlock Grid.Row="11"
                           Grid.ColumnSpan="2"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{DynamicResource ButtonSave}" Command="{Binding SaveCommand}" />
            <Button Content="{DynamicResource ButtonClose}"
                    Margin="0"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
